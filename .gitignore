# Ignore everything by default
*

# Keep gitignore itself
!.gitignore

# Keep project metadata / docs
!README.md
!CMakeLists.txt

# Keep source code folders
!src/
!src/**
!include/
!include/**

# Keep common source/header files at root if you ever add them
!*.cpp
!*.cc
!*.c
!*.h
!*.hpp
!*.hh
!*.inl

# Keep common build/config text files if needed
!*.txt
!*.md
!*.cmake